# ── Server ────────────────────────────────────────────────────────────────────
PORT=5050
NODE_ENV=development             # set to "production" when deployed

# ── Database ──────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/servicemarketplace

# ── Auth ─────────────────────────────────────────────────────────────────────
# Generate with: node -e "require('crypto').randomBytes(64).toString('hex')"
JWT_SECRET=REPLACE_WITH_64_CHAR_RANDOM_HEX_STRING

# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=http://localhost:3000,https://yourdomain.com

# ── Frontend URL (used in email links) ────────────────────────────────────────
# Set this to your real domain in production — all email CTAs use this value.
# Example: https://www.servicemarket.in
FRONTEND_URL=http://localhost:3000

# ── Proxy / Load Balancer ─────────────────────────────────────────────────────
# Set to "1" if running behind Nginx / Railway / Render / Heroku
TRUST_PROXY=0

# ── Background Verification (IDfy) ───────────────────────────────────────────
# Get credentials at https://app.idfy.io — leave blank in development (stub returns "pending")
IDFY_API_KEY=
IDFY_ACCOUNT_ID=

# ── Email (SMTP) ──────────────────────────────────────────────────────────────
# Use OAuth2 or a transactional service (Resend, SendGrid) in production
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-gmail-app-password
SMTP_FROM=your-email@gmail.com
